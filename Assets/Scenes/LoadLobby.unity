--- !u!114 &1671788150
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1671788146}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 0faaf6a80a3ed7b42b7711e089b8ce6d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  tipText: {fileID: 1671788148}
  tips:
  - "\u0415\u0441\u043B\u0438 \u0443\u0431\u0438\u0432\u0430\u0435\u0448\u044C \u0441\u043B\u0438\u0437\u043D\u044F\u043A\u043E\u0432,
    \u0442\u043E \u043D\u0435 \u0437\u0430\u0431\u044B\u0432\u0430\u0439 ..."
  - "\u0428\u0440\u0435\u043A\u0430 \u043D\u0435 \u0431\u0443\u0434\u0435\u0442 (\u0431\u0443\u0434\u0435\u0442)."
  - "\u041C\u044B \u0441\u0434\u0430\u043B\u0438?"
  - "\"\u0417\u0430\u0433\u0440\u0443\u0437\u043A\u0430... \u0438\u043B\u0438 \u043A\u0430\u043A
    \u044F \u043B\u044E\u0431\u043B\u044E \u043D\u0430\u0437\u044B\u0432\u0430\u0442\u044C
    \u044D\u0442\u043E, '\u043F\u0435\u0440\u0435\u0437\u0430\u0433\u0440\u0443\u0437\u043A\u0430
    \u043C\u043E\u0437\u0433\u0430'\""
  - "\u0413\u043B\u0430\u0432\u043D\u043E\u0435 \u2014 \u043D\u0435 \u0443\u043C\u0435\u0440\u0435\u0442\u044C
    \u0432 \u043F\u0435\u0440\u0432\u044B\u0435 \u043F\u044F\u0442\u044C \u043C\u0438\u043D\u0443\u0442."
  - "\u0412\u043C\u0435\u0441\u0442\u043E \u0444\u044D\u043D\u0442\u0435\u0437\u0438-\u043C\u0438\u0440\u0430
    \u0441 \u0433\u0430\u0440\u0435\u043C\u043E\u043C... \u0433\u043D\u0438\u043B\u043E\u0439
    \u043B\u0435\u0441?"
  - "\u0418\u043D\u0442\u0435\u0440\u0435\u0441\u043D\u043E, \u0430 \u0442\u0443\u0442
    \u0435\u0441\u0442\u044C \u0432\u0430\u0439\u0444\u0430\u0439? "
  - "\u041F\u0440\u0438\u0432\u0435\u0442 \u0410\u043B\u0438\u0441\u0430, \u043A\u0430\u043A
    \u0432\u044B\u0436\u0438\u0442\u044C \u0432 \u043F\u0440\u043E\u043A\u043B\u044F\u0442\u043E\u043C
    \u043B\u0435\u0441\u0443?"
  - "\u041D\u0443 \u0438 \u0433\u0434\u0435 \u0442\u0443\u0442 \u043A\u043D\u043E\u043F\u043A\u0430
    '\u043F\u0440\u043E\u043F\u0443\u0441\u0442\u0438\u0442\u044C \u0431\u043E\u0439'?"
  - "\u0410 \u0443 \u0432\u0430\u0441 \u0442\u0443\u0442 \u0441\u043B\u0443\u0447\u0430\u0439\u043D\u043E
    \u043D\u0435\u0442 \u0447\u0435\u0433\u043E-\u043D\u0438\u0431\u0443\u0434\u044C
    \u043F\u043E\u043A\u0440\u0435\u043F\u0447\u0435 \u0432\u043E\u0434\u044B?"
  - "\u0427\u0442\u043E\u0431\u044B \u0430\u0442\u0430\u043A\u043E\u0432\u0430\u0442\u044C
    \u043F\u0440\u043E\u0442\u0438\u0432\u043D\u0438\u043A\u0430, \u043D\u0430\u0436\u043C\u0438\u0442\u0435
    \u043A\u043D\u043E\u043F\u043A\u0443 \u0430\u0442\u0430\u043A\u0438"
  - "\u041E\u0440\u0443\u0436\u0438\u0435 \u0443\u043C\u0435\u0435\u0442 \u043B\u043E\u043C\u0430\u0442\u044C\u0441\u044F,
    \u043D\u0435 \u0437\u0430\u0431\u044B\u0432\u0430\u0439, \u0435\u043C\u0430\u0435"
  - "\u0413\u043B\u0443\u043F\u044B\u0435 \u0431\u0430\u0440\u044C\u0435\u0440\u044B..."
  - "\u041C\u044F\u0443."
  - "\u0410\u0433\u0430, \u043A\u043E\u043D\u0435\u0447\u043D\u043E. \u041A\u0430\u043A
    \u0432 \u0442\u043E\u043C \u0441\u0430\u043C\u043E\u043C \u0430\u043D\u0438\u043C\u0435:
    '\u0422\u044B \u0443\u043C\u0435\u0440, \u043D\u043E \u043C\u043E\u0436\u0435\u0448\u044C
    \u043D\u0430\u0447\u0430\u0442\u044C \u0441\u043D\u0430\u0447\u0430\u043B\u0430!'
    \u0422\u043E\u043B\u044C\u043A\u043E \u0432\u043E\u0442 \u0433\u0434\u0435 \u043C\u043E\u044F
    \u0431\u043E\u0433\u0438\u043D\u044F \u0441 \u0447\u0430\u0439\u043D\u0438\u043A\u043E\u043C?"
  - "\u041D\u0435 \u043D\u0430\u0436\u0438\u043C\u0430\u0439 \"J\"..."
  - "\u041D\u0435 \u043D\u0430\u0436\u0438\u043C\u0430\u0439 \"J\"..."
