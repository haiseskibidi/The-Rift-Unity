  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "\u0410\u0433\u0430, \u043A\u043E\u043D\u0435\u0447\u043D\u043E. \u041A\u0430\u043A
    \u0432 \u0442\u043E\u043C \u0441\u0430\u043C\u043E\u043C \u0430\u043D\u0438\u043C\u0435:
    '\u0422\u044B \u0443\u043C\u0435\u0440, \u043D\u043E \u043C\u043E\u0436\u0435\u0448\u044C
    \u043D\u0430\u0447\u0430\u0442\u044C \u0441\u043D\u0430\u0447\u0430\u043B\u0430!'
    \u0422\u043E\u043B\u044C\u043A\u043E \u0432\u043E\u0442 \u0433\u0434\u0435 \u043C\u043E\u044F
    \u0431\u043E\u0433\u0438\u043D\u044F \u0441 \u0447\u0430\u0439\u043D\u0438\u043A\u043E\u043C?"
